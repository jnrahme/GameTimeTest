{
  "name": "gametime-order-history",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "engines": {
    "node": ">=22.13.0 <23",
    "npm": ">=10.9.0"
  },
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~56.0.12",
    "expo-linear-gradient": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "lucide-react-native": "^1.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --coverage",
    "test:watch": "jest --watch",
    "verify": "npm run typecheck && npm test"
  },
  "jest": {
    "preset": "jest-expo",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "App.tsx",
      "!src/**/*.test.{ts,tsx}",
      "!App.test.tsx"
    ],
    "coverageReporters": [
      "text-summary",
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 95,
        "statements": 95
      }
    },
    "testMatch": [
      "**/*.test.ts",
      "**/*.test.tsx"
    ]
  }
}
